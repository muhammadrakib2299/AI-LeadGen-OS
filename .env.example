# Copy to .env for local dev. Never commit .env.
# For production, use a secrets manager (Doppler or Infisical) — see README.md.

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=dev
LOG_LEVEL=INFO
JURISDICTION=EU

# ── Database (Postgres 16) ──────────────────────────────────
# Matches docker-compose.yml service
DATABASE_URL=postgresql+asyncpg://leadgen:leadgen@127.0.0.1:55432/leadgen

# ── Cache / queue (Redis 7) ─────────────────────────────────
REDIS_URL=redis://127.0.0.1:6380/0

# ── Discovery APIs ──────────────────────────────────────────
# Required for Phase 1. Get from https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=

# ── LLM extraction ──────────────────────────────────────────
# Pick one. Anthropic recommended (Haiku = cheap extraction tier).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Enrichment (Phase 2) ────────────────────────────────────
HUNTER_API_KEY=

# ── Yelp Fusion (Phase 3 fallback discovery) ────────────────
# Free tier: 5,000 RPD. Get from https://www.yelp.com/developers
# Yelp ToS limits storage of API data to 24h (except the business ID),
# which the retention sweep enforces on raw_fetches.payload.
YELP_API_KEY=

# ── Search fallback (Phase 2) ───────────────────────────────
SERPER_API_KEY=

# ── Observability ───────────────────────────────────────────
# Create project at https://sentry.io (EU region) and paste DSN here.
SENTRY_DSN=

# ── Scraper politeness ──────────────────────────────────────
DEFAULT_USER_AGENT=AI-LeadGen-OS/0.1 (+https://combosoft.co.uk/bot)
PER_DOMAIN_MIN_INTERVAL_SECONDS=2.0

# ── Budget guard ────────────────────────────────────────────
JOB_BUDGET_CAP_USD=5.0

# ── Compliant Mode (Cross-cutting compliance) ───────────────
# When true, the pipeline uses only Tier-1 official APIs with clear ToS
# (Google Places, OpenCorporates). Yelp (24h data rule) and the crawler
# (scraping fallback) are disabled. Enables a "safe for EU clients" mode
# at the cost of email/phone discovery from websites.
COMPLIANT_MODE=false

# ── PII encryption at rest ──────────────────────────────────
# Fernet key — generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotate via APP_ENCRYPTION_KEY + APP_ENCRYPTION_KEY_PREVIOUS (TODO: wire
# rotation separately). Leave unset to disable column-level encryption
# (disk-level encryption remains the primary control).
APP_ENCRYPTION_KEY=

# ── Auth (Phase 4) ──────────────────────────────────────────
# MUST be set to a strong random value in prod (e.g. `openssl rand -hex 32`).
# The in-code default is deliberately insecure so that a prod deploy without
# this var fails loudly rather than using a guessable key.
JWT_SECRET=dev-insecure-change-me
JWT_TTL_SECONDS=604800
